    "devops",
    "express"
  ],
  "author": "Gentleman08",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Gentleman08/automated-web-deployment/issues"
  },
  "homepage": "https://github.com/Gentleman08/automated-web-deployment#readme",
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
