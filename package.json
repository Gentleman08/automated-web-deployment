{
  "name": "automated-ci_cd",
  "version": "1.0.0",
  "description": "Automated CI/CD Pipeline for Web Application Deployment",
  "main": "src/app.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --coverage --detectOpenHandles",
